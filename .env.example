GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
SESSION_SECRET=change_this_to_a_long_random_string
REDIS_URL=redis://default:password@host:6379
PORT=3000
# Netscape cookies.txt içeriğini (düz metin) buraya yapıştırabilirsiniz.
# Google + YouTube cookie satırları aynı değer içinde art arda olabilir.
YTDLP_COOKIES=# Netscape HTTP Cookie File
YTDLP_COOKIES_B64=base64_netscape_cookie_text
YTDLP_COOKIES_GOOGLE_B64=
YTDLP_COOKIES_YOUTUBE_B64=
YTDLP_PROXY=http://user:pass@host:port
YTDLP_FORCE_IPV4=1
